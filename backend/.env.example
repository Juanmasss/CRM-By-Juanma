# ── App (PASO 0) ─────────────────────────────
NODE_ENV=development
PORT=4000
WEB_URL=http://localhost:5173
API_URL=http://localhost:4000

# ── Supabase (B1) ────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=   # pooler 6543, agrega ?pgbouncer=true&connection_limit=1
DIRECT_URL=     # directo 5432 (para migraciones)

# ── whatsapp-service (B6) ────────────────────
WA_SERVICE_PORT=4100
WA_AUTH_DIR=./auth
WA_SERVICE_URL=http://localhost:4100
BACKEND_INTERNAL_URL=http://localhost:4000
INTERNAL_API_SECRET=          # string secreto que inventas (servicio↔backend)

# ── Perplexity (B8) ──────────────────────────
PERPLEXITY_API_KEY=           # pplx-... (genérala en developer settings; es SEPARADO de Pro)
PERPLEXITY_MODEL=sonar
PERPLEXITY_BASE_URL=https://api.perplexity.ai
